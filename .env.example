# Cavoti dashboard key(s). Generate at https://cavoti.com.
#
# Single key:
#   CAVOTI_API_KEY=sk-replace-me
#
# Or a pool of keys (comma-separated). Requests rotate through the pool and
# fail over to the next key automatically when one returns nothing, errors,
# or is rate-limited — applies to every model.
CAVOTI_API_KEYS=sk-key-one,sk-key-two,sk-key-three

# Optional. Override the relay base URL.
CAVOTI_BASE_URL=https://cavoti.com/v1

# Optional. The model selected on first load.
CAVOTI_DEFAULT_MODEL=gpt-5.4

# Optional. Per-request timeout (ms). Defaults to 120000.
CAVOTI_TIMEOUT_MS=120000

# SQLite database location (read by Prisma CLI and the Next runtime).
# Path is relative to the prisma/ folder, so this lands at prisma/dev.db.
DATABASE_URL="file:./dev.db"

# ── Auth (prototype) ────────────────────────────────────────────────────────
# Secret used to sign session cookies. Use a long random string in real use.
SESSION_SECRET=change-me-to-a-long-random-string
# Admin login. Username matching ADMIN_USERNAME + ADMIN_PASSWORD lands on /admin.
# Any other non-empty username/password logs in as a regular user (demo mode).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-strong-password

# Key for encrypting uploaded files at rest. If unset, SESSION_SECRET is used.
UPLOAD_SECRET=change-me-to-another-long-random-string

# Optional. Directory for encrypted upload blobs. Defaults to ./.uploads locally.
# On Railway (or any persistent-volume host) point this at the mounted volume,
# e.g. /data/uploads, so files survive restarts.
# UPLOAD_DIR=/data/uploads
#
# On a deploy, also set DATABASE_URL to the volume, e.g.:
#   DATABASE_URL=file:/data/dev.db
